    Matches input procedure with master dictionary and returns the best matching level.
    """
    input_embedding = model.encode(input_procedure, convert_to_tensor=True)
    
    # Compute cosine similarities
    similarities = df["Embedding"].apply(lambda emb: float(util.cos_sim(input_embedding, emb)))

    # Find top match
    top_match_idx = similarities.idxmax()
